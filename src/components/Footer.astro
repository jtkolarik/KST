---
const currentYear = new Date().getFullYear();
---

<footer class="bg-warmgray-700 border-t border-warmgray-600">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="inline-block mb-4 hover:opacity-80 transition-opacity">
          <img src="/logo.png" alt="Kolarik Speech Therapy" class="h-14 md:h-20" />
        </a>
        <p class="text-warmgray-400 text-sm">
          Play-based speech sound groups for kids in Kansas City. Small groups, big progress.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-semibold text-white mb-3">Quick Links</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/sound-groups/" class="text-warmgray-400 hover:text-white transition-colors">Sound Groups</a></li>
          <li><a href="/register/" class="text-warmgray-400 hover:text-white transition-colors">Register</a></li>
          <li><a href="/about/" class="text-warmgray-400 hover:text-white transition-colors">About Molly</a></li>
          <li><a href="/contact/" class="text-warmgray-400 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-white mb-3">Get in Touch</h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="#" class="text-warmgray-400 hover:text-white transition-colors phone-link">
              <span class="phone-text"></span>
            </a>
          </li>
          <li>
            <a href="mailto:kolarikspeechtherapy@gmail.com" class="text-warmgray-400 hover:text-white transition-colors">
              kolarikspeechtherapy@gmail.com
            </a>
          </li>
          <li class="text-warmgray-400">
            Serving the KC Metro Area
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-warmgray-600 mt-8 pt-8 text-center text-sm text-warmgray-400">
      <p>&copy; {currentYear} Kolarik Speech Therapy LLC. All rights reserved.</p>
      <p class="mt-2">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
      </p>
    </div>
  </div>
</footer>
