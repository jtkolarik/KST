---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You" description="Your message has been received. Molly will be in touch soon.">
  <section class="py-24">
    <div class="max-w-2xl mx-auto px-4 text-center animate-on-scroll">
      <div class="w-20 h-20 bg-sage-100 rounded-full flex items-center justify-center mx-auto mb-8">
        <svg class="w-10 h-10 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h1 class="text-4xl font-bold text-warmgray-700 mb-4">Thank You!</h1>
      <p class="text-lg text-warmgray-500 mb-8 leading-relaxed">
        Your message has been received. Molly will reach out within 24 hours.
      </p>
      <a
        href="/"
        class="btn-hover inline-block bg-sage-400 text-white px-8 py-3 rounded-lg font-semibold hover:bg-sage-500"
      >
        Back to Home
      </a>
    </div>
  </section>
</Layout>
