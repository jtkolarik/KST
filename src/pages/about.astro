---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Molly Kolarik" description="Meet Molly Kolarik, CCC-SLP — a pediatric speech sound specialist serving families across the Kansas City metro area with play-based speech sound groups.">
  <!-- Hero Section -->
  <section class="relative py-16 bg-gradient-to-b from-white to-sage-50">
    <div class="absolute inset-0 bg-[url('/background-texture.png')] bg-cover bg-center opacity-40 pointer-events-none"></div>
    <div class="relative max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <h1 class="text-4xl md:text-5xl font-bold text-warmgray-700 mb-6">
            Meet Molly Kolarik
          </h1>
          <p class="text-lg text-warmgray-500 leading-relaxed mb-6">
            I'm a pediatric speech-language pathologist serving families across the Kansas City metro area. I specialize in speech sounds — helping kids learn to speak clearly and confidently through play-based group sessions.
          </p>
          <p class="text-warmgray-500 leading-relaxed">
            <span class="font-semibold text-warmgray-700">Credentials:</span> M.S. in Speech-Language Pathology, CCC-SLP
          </p>
        </div>
        <div class="flex justify-center animate-on-scroll stagger-1">
          <img
            src="/headshot-2.jpg"
            alt="Molly Kolarik, Pediatric Speech-Language Pathologist"
            class="rounded-2xl shadow-lg max-w-md w-full img-hover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Background Section -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="animate-on-scroll">
        <h2 class="text-3xl font-bold text-warmgray-700 mb-6">My Background</h2>
        <div class="flex flex-col sm:flex-row gap-8 items-start">
          <div class="flex-1 space-y-4 text-warmgray-500 leading-relaxed">
            <p>
              I earned my Master's degree in Speech-Language Pathology from the University of Central Missouri and hold my Certificate of Clinical Competence (CCC-SLP) from the American Speech-Language-Hearing Association.
            </p>
            <p>
              I've worked with children ages 3 and up, with a special focus on speech sound disorders — helping kids who are hard to understand, substitute sounds, or struggle to say certain sounds clearly. I love finding creative, play-based ways to make speech practice feel like fun.
            </p>
          </div>
          <div class="flex-shrink-0">
            <img
              src="/asha-certified.png"
              alt="ASHA Certified Speech-Language Pathologist"
              class="w-28 h-auto"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why I Started Section -->
  <section class="py-16 bg-sage-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="order-2 md:order-1 flex justify-center animate-on-scroll">
          <img
            src="/gallery 4.jpg"
            alt="Molly working with children on speech sounds"
            class="rounded-2xl shadow-lg max-w-md w-full img-hover"
          />
        </div>
        <div class="order-1 md:order-2 animate-on-scroll stagger-1">
          <h2 class="text-3xl font-bold text-warmgray-700 mb-6">Why I Started Sound Groups</h2>
          <div class="space-y-4 text-warmgray-500 leading-relaxed">
            <p>
              I saw too many families struggle to access speech therapy — overwhelmed by complicated intake processes, confusing referral systems, and costs that felt out of reach. I knew there had to be a better way.
            </p>
            <p>
              Sound Groups are my answer to that. Small group sessions that are affordable, easy to start, and genuinely fun for kids. No complicated paperwork, no insurance headaches — just quality speech therapy your family can count on.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- My Approach Section -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-warmgray-700 text-center mb-12 animate-on-scroll">My Approach</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="animate-on-scroll stagger-1 bg-sage-50 rounded-xl p-8 card-hover border border-sage-200">
          <div class="w-12 h-12 bg-sage-200 rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-warmgray-700 mb-3">Play-Based</h3>
          <p class="text-warmgray-500">
            Therapy should feel like fun, not work. I use games, activities, and peer interaction to build speech skills naturally.
          </p>
        </div>
        <div class="animate-on-scroll stagger-2 bg-sage-50 rounded-xl p-8 card-hover border border-sage-200">
          <div class="w-12 h-12 bg-sage-200 rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-warmgray-700 mb-3">Peer-Powered</h3>
          <p class="text-warmgray-500">
            Kids learn best alongside other kids. Group sessions build confidence and make practice feel natural and encouraging.
          </p>
        </div>
        <div class="animate-on-scroll stagger-3 bg-sage-50 rounded-xl p-8 card-hover border border-sage-200">
          <div class="w-12 h-12 bg-sage-200 rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-warmgray-700 mb-3">Family-Centered</h3>
          <p class="text-warmgray-500">
            I keep parents in the loop with simple strategies you can use between sessions to keep progress going at home.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-sage-400">
    <div class="max-w-4xl mx-auto px-4 text-center animate-on-scroll">
      <h2 class="text-3xl font-bold text-white mb-4">
        Let's Talk About Your Child
      </h2>
      <p class="text-sage-100 text-lg mb-8">
        I'd love to hear your story and answer any questions you have. Reserve a spot or give me a call — I'm here to help.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/register/"
          class="btn-hover inline-block bg-white text-sage-500 px-8 py-3 rounded-lg font-semibold hover:bg-sage-50"
        >
          Reserve a Spot for Fall 2026
        </a>
        <a
          href="#"
          class="inline-block border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors phone-link"
        >
          Call <span class="phone-text"></span>
        </a>
      </div>
    </div>
  </section>
</Layout>
