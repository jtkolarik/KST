---
import Layout from '../layouts/Layout.astro';

const galleryImages = [
  { src: '/gallery 1.jpg', alt: 'Child engaged in play-based speech therapy activity' },
  { src: '/gallery 2.jpg', alt: 'Speech therapist working with child on speech sounds' },
  { src: '/gallery 3.jpg', alt: 'Play-based speech therapy session in Kansas City' },
  { src: '/gallery 4.jpg', alt: 'Pediatric speech therapy using interactive learning' },
  { src: '/gallery 5.jpg', alt: 'Child practicing speech sounds during therapy' },
  { src: '/gallery 6.jpg', alt: 'Fun speech therapy session with kids' },
];
---

<Layout title="Speech Sound Groups for Kids | Kansas City">
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-b from-white to-sage-50 py-10 md:py-14">
    <div class="absolute inset-0 bg-[url('/background-texture.png')] bg-cover bg-center opacity-40 pointer-events-none"></div>
    <div class="relative max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div class="animate-on-scroll">
          <h1 class="text-4xl md:text-5xl font-bold text-warmgray-700 mb-4 leading-tight">
            Help Your Child
            <span class="text-sage-500">Find Their Voice</span>
          </h1>
          <p class="text-lg text-warmgray-500 mb-6 leading-relaxed">
            Sound Groups are small, play-based sessions where kids work on speech sounds together. Pick a time, show up, and let Molly handle the rest. It's that simple.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="/register/"
              class="btn-hover inline-block bg-sage-400 text-white px-8 py-3 rounded-lg font-semibold hover:bg-sage-500 text-center"
            >
              Reserve a Spot for June 2026
            </a>
            <a
              href="#"
              class="inline-block border-2 border-sage-400 text-sage-500 px-8 py-3 rounded-lg font-semibold text-center hover:bg-sage-50 transition-colors phone-link"
            >
              Call <span class="phone-text"></span>
            </a>
          </div>
        </div>
        <div class="flex justify-center animate-on-scroll stagger-1">
          <img
            src="/headshot.png"
            alt="Molly Kolarik, Pediatric Speech Sound Specialist in Kansas City"
            class="rounded-2xl shadow-lg max-w-[280px] md:max-w-xs w-full img-hover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy / Parent Intro -->
  <section class="pt-16 pb-10 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-warmgray-700 text-center mb-12 animate-on-scroll">
        Why I Created Sound Groups
      </h2>
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div class="animate-on-scroll">
          <div class="bg-sage-50 rounded-2xl p-8 border-l-4 border-l-sage-400 border border-sage-300 shadow-sm card-hover">
            <svg class="w-8 h-8 text-sage-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
            <p class="text-lg text-warmgray-500 leading-relaxed">
              As a mom, I know what it's like — worrying whether your child is on track, wondering if you should "wait and see," and trying to squeeze one more appointment into an already-packed week. I created Sound Groups so Kansas City families could get their child expert speech therapy without adding more stress to an already full plate.
            </p>
          </div>
        </div>
        <div class="animate-on-scroll stagger-1">
          <div class="space-y-4">
            <div class="flex items-start gap-4 p-5 bg-sage-50 rounded-lg border border-sage-300 shadow-sm border-l-4 border-l-sage-400 card-hover">
              <svg class="w-6 h-6 text-sage-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <p class="text-warmgray-500"><span class="font-semibold text-warmgray-700">Small, play-based sessions</span> where kids work on speech sounds together</p>
            </div>
            <div class="flex items-start gap-4 p-5 bg-sage-50 rounded-lg border border-sage-300 shadow-sm border-l-4 border-l-sage-400 card-hover">
              <svg class="w-6 h-6 text-sage-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <p class="text-warmgray-500"><span class="font-semibold text-warmgray-700">Led by a certified speech-language pathologist</span> who specializes in speech sounds</p>
            </div>
            <div class="flex items-start gap-4 p-5 bg-sage-50 rounded-lg border border-sage-300 shadow-sm border-l-4 border-l-sage-400 card-hover">
              <svg class="w-6 h-6 text-sage-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <p class="text-warmgray-500"><span class="font-semibold text-warmgray-700">No lengthy intake or insurance paperwork</span> — you pick a time, show up, and I handle the rest</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section Divider -->
  <div class="bg-white flex justify-center py-2">
    <img src="/branch-divider.png" alt="" class="w-56 md:w-72 h-auto opacity-60" />
  </div>

  <!-- Signs Section -->
  <section class="pt-10 pb-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="animate-on-scroll">
        <h2 class="text-3xl font-bold text-warmgray-700 text-center mb-4">
          Is Your Child Hard to Understand?
        </h2>
        <p class="text-lg text-warmgray-500 text-center max-w-3xl mx-auto mb-12">
          If people outside your family have a hard time understanding your child, or if your child gets frustrated trying to say certain words, Sound Groups can help.
        </p>
      </div>

      <div class="max-w-3xl mx-auto">
        <h3 class="text-xl font-semibold text-warmgray-700 mb-6 animate-on-scroll">Common signs parents notice:</h3>
        <div class="grid sm:grid-cols-2 gap-4">
          <div class="animate-on-scroll stagger-1 flex items-start gap-3 p-4 bg-sage-50 rounded-lg card-hover border border-sage-200">
            <svg class="w-6 h-6 text-sage-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-warmgray-600">Difficulty being understood by others</span>
          </div>
          <div class="animate-on-scroll stagger-2 flex items-start gap-3 p-4 bg-sage-50 rounded-lg card-hover border border-sage-200">
            <svg class="w-6 h-6 text-sage-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-warmgray-600">Substituting one sound for another</span>
          </div>
          <div class="animate-on-scroll stagger-3 flex items-start gap-3 p-4 bg-sage-50 rounded-lg card-hover border border-sage-200">
            <svg class="w-6 h-6 text-sage-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-warmgray-600">Leaving sounds off the beginning or end of words</span>
          </div>
          <div class="animate-on-scroll stagger-4 flex items-start gap-3 p-4 bg-sage-50 rounded-lg card-hover border border-sage-200">
            <svg class="w-6 h-6 text-sage-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-warmgray-600">Frustration when trying to communicate</span>
          </div>
          <div class="animate-on-scroll stagger-1 flex items-start gap-3 p-4 bg-sage-50 rounded-lg card-hover border border-sage-200">
            <svg class="w-6 h-6 text-sage-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-warmgray-600">Speech that's unclear compared to peers</span>
          </div>
          <div class="animate-on-scroll stagger-2 flex items-start gap-3 p-4 bg-sage-50 rounded-lg card-hover border border-sage-200">
            <svg class="w-6 h-6 text-sage-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-warmgray-600">Not meeting speech milestones for their age</span>
          </div>
        </div>
        <p class="text-warmgray-500 mt-8 text-center animate-on-scroll">
          <strong class="text-warmgray-700">You know your child best.</strong> If something feels off, it's worth exploring. A quick call with Molly can give you clarity — and a path forward.
        </p>
      </div>
    </div>
  </section>

  <!-- How Sound Groups Work -->
  <section class="py-16 bg-sage-50">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-warmgray-700 text-center mb-12 animate-on-scroll">
        How Sound Groups Work
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center animate-on-scroll stagger-1">
          <div class="w-16 h-16 bg-sage-400 text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-bold">1</div>
          <h3 class="text-xl font-semibold text-warmgray-700 mb-2">Sign Up</h3>
          <p class="text-warmgray-500">
            Fill out a quick form and Molly will match your child to the right group.
          </p>
        </div>
        <div class="text-center animate-on-scroll stagger-2">
          <div class="w-16 h-16 bg-sage-400 text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-bold">2</div>
          <h3 class="text-xl font-semibold text-warmgray-700 mb-2">Show Up</h3>
          <p class="text-warmgray-500">
            Bring your child to a 30-minute session. Molly handles the rest — no prep needed.
          </p>
        </div>
        <div class="text-center animate-on-scroll stagger-3">
          <div class="w-16 h-16 bg-sage-400 text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-bold">3</div>
          <h3 class="text-xl font-semibold text-warmgray-700 mb-2">Watch Them Grow</h3>
          <p class="text-warmgray-500">
            See real progress as your child practices speech sounds each week alongside peers.
          </p>
        </div>
      </div>
      <div class="text-center mt-10 animate-on-scroll">
        <a href="/sound-groups/" class="text-sage-500 font-semibold hover:text-sage-600 transition-colors link-hover">
          Learn more about Sound Groups →
        </a>
      </div>
    </div>
  </section>

  <!-- Photo Gallery Banner -->
  <section class="py-12 bg-sage-100 overflow-hidden">
    <div class="relative">
      <div class="gallery-scroll flex gap-4" style="width: max-content;">
        {galleryImages.map((image) => (
          <div class="flex-shrink-0 w-52 md:w-72 h-36 md:h-48 rounded-xl overflow-hidden shadow-md">
            <img
              src={image.src}
              alt={image.alt}
              class="w-full h-full object-cover"
            />
          </div>
        ))}
        {galleryImages.map((image) => (
          <div class="flex-shrink-0 w-52 md:w-72 h-36 md:h-48 rounded-xl overflow-hidden shadow-md">
            <img
              src={image.src}
              alt={image.alt}
              class="w-full h-full object-cover"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Meet Molly Section -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center animate-on-scroll">
        <h2 class="text-3xl font-bold text-warmgray-700 mb-6">
          Meet Molly Kolarik, CCC-SLP
        </h2>
        <p class="text-lg text-warmgray-500 mb-8 leading-relaxed">
          Hi, I'm Molly — a licensed speech-language pathologist with a Master's degree from the University of Central Missouri and my Certificate of Clinical Competence (CCC-SLP). I specialize in helping kids master their speech sounds, and I bring professional expertise and genuine care to every session.
        </p>
        <a
          href="/about/"
          class="inline-block text-sage-500 font-semibold hover:text-sage-600 transition-colors link-hover"
        >
          Learn more about my approach →
        </a>
      </div>
    </div>
  </section>

  <!-- Pricing Teaser -->
  <section class="py-16 bg-sage-50">
    <div class="max-w-xl mx-auto px-4 animate-on-scroll">
      <div class="bg-white rounded-2xl shadow-sm border border-sage-200 overflow-hidden">
        <div class="bg-sage-400 py-3 px-6 text-center">
          <p class="text-white font-semibold tracking-wide text-sm uppercase">Sound Groups</p>
        </div>
        <div class="p-8 text-center">
          <p class="text-5xl font-bold text-warmgray-700 mb-1">$50</p>
          <p class="text-warmgray-400 font-medium mb-6">per session · 30 minutes</p>
          <div class="space-y-3 text-left max-w-xs mx-auto mb-8">
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-sage-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-warmgray-500">Small groups of 2–4 kids</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-sage-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-warmgray-500">No contracts or commitments</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-sage-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-warmgray-500">No insurance needed — simple private pay</span>
            </div>
          </div>
          <a
            href="/register/"
            class="btn-hover inline-block bg-sage-400 text-white px-8 py-3 rounded-lg font-semibold hover:bg-sage-500 text-center w-full"
          >
            Reserve a Spot for June 2026
          </a>
          <a href="/sound-groups/" class="inline-block mt-4 text-sage-500 font-semibold hover:text-sage-600 transition-colors link-hover text-sm">
            Learn more about Sound Groups →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-warmgray-700 text-center mb-12 animate-on-scroll">
        What Parents Are Saying
      </h2>

      <div class="relative animate-on-scroll">
        <div class="testimonial-container overflow-hidden">
          <div class="testimonial-track flex transition-transform duration-500 ease-in-out">

            <div class="testimonial-slide min-w-full px-4">
              <div class="bg-sage-50 rounded-xl p-8 border border-sage-200">
                <svg class="w-8 h-8 text-sage-300 mb-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
                </svg>
                <p class="text-warmgray-600 text-lg mb-4">
                  Our son was so frustrated — he'd try to say something and no one outside the family could understand him. Once he started working with Molly, he began making sounds we'd never heard from him before. He actually asks to go back, which says a lot.
                </p>
                <p class="text-warmgray-500 font-medium">— James T.</p>
              </div>
            </div>

            <div class="testimonial-slide min-w-full px-4">
              <div class="bg-sage-50 rounded-xl p-8 border border-sage-200">
                <svg class="w-8 h-8 text-sage-300 mb-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
                </svg>
                <p class="text-warmgray-600 text-lg mb-4">
                  I was nervous about group therapy at first — I thought my daughter would shut down around other kids. But Molly made it so comfortable. She opened up in ways I didn't expect, and now she's so much more confident talking to her preschool teachers.
                </p>
                <p class="text-warmgray-500 font-medium">— Emily R.</p>
              </div>
            </div>

            <div class="testimonial-slide min-w-full px-4">
              <div class="bg-sage-50 rounded-xl p-8 border border-sage-200">
                <svg class="w-8 h-8 text-sage-300 mb-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
                </svg>
                <p class="text-warmgray-600 text-lg mb-4">
                  What I love is how natural it feels. It's not clinical — it's just kids playing and practicing together. My son doesn't even realize he's in therapy. He thinks he's going to hang out with his friends. And honestly, the progress has been incredible.
                </p>
                <p class="text-warmgray-500 font-medium">— Megan D.</p>
              </div>
            </div>

          </div>
        </div>

        <div class="flex justify-center gap-2 mt-6" role="tablist" aria-label="Testimonial navigation">
          <button class="testimonial-dot w-3 h-3 rounded-full bg-sage-400 transition-colors" data-index="0" role="tab" aria-selected="true" aria-label="View testimonial 1 of 3"></button>
          <button class="testimonial-dot w-3 h-3 rounded-full bg-sage-200 hover:bg-sage-300 transition-colors" data-index="1" role="tab" aria-selected="false" aria-label="View testimonial 2 of 3"></button>
          <button class="testimonial-dot w-3 h-3 rounded-full bg-sage-200 hover:bg-sage-300 transition-colors" data-index="2" role="tab" aria-selected="false" aria-label="View testimonial 3 of 3"></button>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Testimonial Carousel
    const track = document.querySelector('.testimonial-track') as HTMLElement;
    const dots = document.querySelectorAll('.testimonial-dot');
    let currentIndex = 0;
    const totalSlides = 3;

    function goToSlide(index: number) {
      currentIndex = index;
      track.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-sage-400', i === index);
        dot.classList.toggle('bg-sage-200', i !== index);
      });
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.getAttribute('data-index') || '0');
        goToSlide(index);
      });
    });

    setInterval(() => {
      goToSlide((currentIndex + 1) % totalSlides);
    }, 12000);
  </script>

  <!-- Final CTA Section -->
  <section class="py-16 bg-sage-400">
    <div class="max-w-4xl mx-auto px-4 text-center animate-on-scroll">
      <h2 class="text-3xl font-bold text-white mb-4">
        June 2026 Enrollment Is Open
      </h2>
      <p class="text-sage-100 text-lg mb-8">
        Spots are limited. Reserve your child's place in a Sound Group and give them a head start on clearer speech.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/register/"
          class="btn-hover inline-block bg-white text-sage-500 px-8 py-3 rounded-lg font-semibold hover:bg-sage-50"
        >
          Reserve Your Child's Spot
        </a>
        <a
          href="#"
          class="inline-block border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors phone-link"
        >
          Call <span class="phone-text"></span>
        </a>
      </div>
    </div>
  </section>
</Layout>
